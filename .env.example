# KAP Classifier — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi doldurun.

# Uygulama ayarları
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ─── KAP Provider ────────────────────────────────
# "mock" → geliştirme ortamı (API key gerekmez)
# "mkk"  → MKK API Portal (resmi üretim ortamı)
KAP_PROVIDER=mock

# ─── MKK API Portal Credentials ──────────────────
# https://apiportal.mkk.com.tr adresinden alınır
# Basic Auth: Authorization: Basic base64(MKK_API_USER:MKK_API_PASS)
MKK_API_USER=your_client_id_here
MKK_API_PASS=your_client_secret_here

# Test: https://apitestint.mkk.com.tr
# Prod: https://apiint.mkk.com.tr
MKK_API_BASE_URL=https://apitestint.mkk.com.tr
MKK_ENV=test

# Cache
CACHE_DIR=.cache

# ─── PostgreSQL (Docker — Ubuntu sunucu) ─────────
# Sunucuda Docker ile PostgreSQL kurulduktan sonra doldurun.
#
PG_HOST=your_server_ip
PG_PORT=5432
PG_DB=kap_db
PG_USER=kap_user
PG_PASSWORD=your_pg_password_here

# ─── Yerel LLM ───────────────────────────────────
# OpenAI kullanılmaz. Gemma modeli local_llm.py / llama-cpp-python üzerinden çalışır.
