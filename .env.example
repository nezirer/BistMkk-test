# KAP Classifier — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi doldurun.

# Uygulama ayarları
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ─── KAP Provider ────────────────────────────────
# "mock" → geliştirme ortamı (API key gerekmez)
# "mkk"  → MKK API Portal (resmi üretim ortamı)
KAP_PROVIDER=mock

# ─── MKK API Portal Credentials ──────────────────
# https://apiportal.mkk.com.tr adresinden alınır
MKK_API_KEY=your_api_key_here

# Test: https://apigwdev.mkk.com.tr  (alternatif: https://apitestint.mkk.com.tr)
# Prod: https://apiint.mkk.com.tr
MKK_API_BASE_URL=https://apigwdev.mkk.com.tr
MKK_ENV=test

# Cache
CACHE_DIR=.cache
